{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rust-air",
  "version": "0.3.40",
  "identifier": "dev.rustair.landrop",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "rust-air",
        "width": 860,
        "height": 600,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "minSdkVersion": 24
    },
    "macOS": {
      "signingIdentity": null
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
